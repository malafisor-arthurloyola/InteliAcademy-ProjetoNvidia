# Copy this file to .env and fill local values.

# LLM providers
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/nvidia_startup_radar

# Vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional reranking
COHERE_API_KEY=

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
