# Copy this file to .env and fill local values.
# Defaults are intentionally offline: no external APIs are called unless the
# project code explicitly enables them and the user authorizes that step.

# LLM providers (primary + fallback chain)
# Primary: RADAR_LLM_PROVIDER=groq (default)
# Fallbacks (ordered): RADAR_LLM_FALLBACKS='["openai","gemini"]'
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# External provider safety switch
# Enable external APIs: set to "true" only with explicit authorization
RADAR_ENABLE_EXTERNAL_PROVIDERS=false
# Search provider: "fixture" (offline mock), "firecrawl", "serpapi", or "duckduckgo"
RADAR_SEARCH_PROVIDER=fixture
# Page provider: "fixture" (offline mock), "firecrawl", or "playwright"
RADAR_PAGE_PROVIDER=fixture
RADAR_PROVIDER_TIMEOUT_SECONDS=10

# Search providers
SERPAPI_API_KEY=

# Page extraction providers (also used for search when RADAR_SEARCH_PROVIDER=firecrawl)
FIRECRAWL_API_KEY=

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/nvidia_startup_radar

# Vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional reranking
COHERE_API_KEY=

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
