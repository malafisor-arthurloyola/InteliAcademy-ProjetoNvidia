# =============================================================================
# NVIDIA Startup AI Radar — Configuracao de Provedores Externos
# =============================================================================
# Copie este arquivo como .env e preencha as chaves que precisar.
# O sistema funciona com defaults (fixture) sem nenhuma chave.
# -----------------------------------------------------------------------------

# --- Ativacao geral ---
# Descomente para usar provedores reais (Firecrawl, SerpAPI, LLMs)
RADAR_ENABLE_EXTERNAL_PROVIDERS=true

# --- Provedores de busca ---
# Opcoes: fixture (mock), firecrawl (API key), serpapi (API key), duckduckgo (gratis)
RADAR_SEARCH_PROVIDER=duckduckgo

# --- Provedores de scraping de paginas ---
# Opcoes: fixture (mock), firecrawl (API key), playwright (gratis, mais lento)
RADAR_PAGE_PROVIDER=playwright

# --- Provedor LLM principal ---
# Opcoes: groq (gratis, padrao), openai, gemini
RADAR_LLM_PROVIDER=groq

# --- Fallbacks LLM (caso o principal falhe) ---
RADAR_LLM_FALLBACKS='["openai","gemini"]'

# --- API Keys ---
# Firecrawl: busca + scraping (plano gratis: 500 paginas/mes)
# Cadastro: https://www.firecrawl.dev
FIRECRAWL_API_KEY=fc_...

# SerpAPI: busca alternativa (plano gratis: 100 buscas/mes)
# Cadastro: https://serpapi.com
SERPAPI_API_KEY=...

# Groq: LLM gratuito, sem chave obrigatoria
# Cadastro: https://console.groq.com
GROQ_API_KEY=gsk_...

# OpenAI: fallback LLM (opcional)
OPENAI_API_KEY=sk-proj-...

# Gemini: fallback LLM (opcional)
GEMINI_API_KEY=AIza...
